# AI VIGILANCE — Environment Configuration
# Copy this file to .env and fill in your values.

ALERT_ENABLED=true
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=587

# Your sending email account credentials
ALERT_SMTP_USER=youraddress@gmail.com

# Gmail: Generate at https://myaccount.google.com/apppasswords
# (Account must have 2FA enabled first)
# Example: "abcd efgh ijkl mnop"  (spaces are fine)
ALERT_SMTP_PASS=xxxx xxxx xxxx xxxx

ALERT_FROM="AI Vigilance <youraddress@gmail.com>"

ALERT_TO=youraddress@gmail.com

ALERT_COOLDOWN=60
ALERT_UNKNOWN=true
